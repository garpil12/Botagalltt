# ========= AMBIL LIST GRUP ADMIN =========
async def get_admin_groups():
    admin_groups = set()
    async for dialog in kntl.iter_dialogs():
        if dialog.is_group or dialog.is_channel:
            try:
                p = await kntl.get_permissions(dialog.id, 'me')
                if p.is_admin:
                    admin_groups.add(dialog.id)
            except:
                pass
    return admin_groups


