send_lock = asyncio.Lock()


# ================= SEND BATCH =================
async def send_batch(chat_id, msg, user_list, emoji_list, mode, progress_msg=None, total_users=None):

    if GLOBAL_STOP or not running_tagall.get(chat_id):
        return

    full_msg = f"{msg}\n\n{' '.join(user_list)}\n{' '.join(emoji_list)}\n\n🛍 my store @storegarf"

    try:
        if GLOBAL_STOP or not running_tagall.get(chat_id):
            return

        # 🔥 LOCK BIAR GA NIMPA (INI KUNCI SMOOTH)
        async with send_lock:

            if mode == "tempel":
                sent_msg = await kntl.send_message(
                    chat_id,
                    full_msg,
                    buttons=[[Button.inline("STOP", b"stop_tagall")]]
                )
            else:
                sent_msg = await msg.reply(
                    full_msg,
                    buttons=[[Button.inline("STOP", b"stop_tagall")]]
                )

            spam_chats.setdefault(f"messages_{chat_id}", []).append(sent_msg.id)
            message_ids.setdefault(chat_id, []).append(sent_msg.id)

            # 🔥 DELAY MINI (ANTI DERES)
            await asyncio.sleep(random.uniform(1.2, 2.0))

    except FloodWaitError as e:
        await asyncio.sleep(min(e.seconds + 2, 15))
    except:
        pass

    if GLOBAL_STOP or not running_tagall.get(chat_id):
        return

    # 🔥 KURANGIN EDIT (BIANG FLOOD)
    if progress_msg and total_users is not None and random.random() > 0.95:
        try:
            async with send_lock:
                await progress_msg.edit(f"⏱ Sedang tagall...")
        except:
            pass


# ================= WORKER =================
async def worker(chat_id, msg, queue, mode, progress_msg, end_time):

    try:
        while running_tagall.get(chat_id) and not GLOBAL_STOP:

            if end_time and time.time() > end_time:
                break

            batch = []

            for _ in range(BATCH_SIZE):

                if GLOBAL_STOP or not running_tagall.get(chat_id):
                    return

                try:
                    batch.append(queue.get_nowait())
                except asyncio.QueueEmpty:
                    break

            if not batch:
                break

            await send_batch(
                chat_id,
                msg,
                batch,
                ["🎯"] * len(batch),
                mode,
                progress_msg,
                len(batch)
            )

            # 🔥 DELAY SMOOTH (GA KAKU)
            base_delay = DELAY + random.uniform(1.0, 2.0)

            for _ in range(int(base_delay * 10)):
                if GLOBAL_STOP or not running_tagall.get(chat_id):
                    return
                await asyncio.sleep(0.1)

    except asyncio.CancelledError:
        return


# ================= START TAGALL =================
async def start_tagall(chat_id, msg, queue, mode, progress_msg=None, end_time=None):
    
    global GLOBAL_STOP
    GLOBAL_STOP = False
    running_tagall[chat_id] = True

    tasks = []

    for _ in range(WORKERS):
        t = asyncio.create_task(worker(chat_id, msg, queue, mode, progress_msg, end_time))
        tasks.append(t)

    tagall_tasks[chat_id] = tasks

    await asyncio.gather(*tasks, return_exceptions=True)

    # 🔥 NOTIF SELESAI
    if not GLOBAL_STOP:
        await kntl.send_message(chat_id, "✅ Tagall selesai!")


# ================= DURASI =================
@kntl.on(events.CallbackQuery(pattern=b"durasi_(.*)"))
async def pilih_durasi(event):
    chat_id = event.chat_id
    data = event.data.decode().split("_")[1]

    setup = spam_chats.get(f"setup_{chat_id}")
    if not setup:
        return await event.answer("Session hilang!", alert=True)

    msg = setup["msg"]
    mode = setup["mode"]

    durasi_map = {
        "2": 120,
        "5": 300,
        "10": 600,
        "30": 1800,
        "60": 3600,
        "unlimited": None
    }

    duration = durasi_map.get(data)

    await event.edit(f"🚀 Tagall jalan {data} menit...")

    # ambil user
    users = []
    async for u in kntl.iter_participants(chat_id):
        if not u.bot and u.first_name:
            users.append(f"[{u.first_name}](tg://user?id={u.id})")

    queue = asyncio.Queue()
    for u in users:
        queue.put_nowait(u)

    running_tagall[chat_id] = True
    end_time = time.time() + duration if duration else None

    progress_msg = await kntl.send_message(chat_id, "⏱ Mulai tagall...")

    tasks = []
    for _ in range(WORKERS):
        tasks.append(asyncio.create_task(
            worker(chat_id, msg, queue, mode, progress_msg, end_time)
        ))

    await asyncio.gather(*tasks)

    running_tagall[chat_id] = False

    await progress_msg.edit(f"✅ DONE tag {len(users)} user")


