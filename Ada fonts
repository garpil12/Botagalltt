@kntl.on(events.CallbackQuery(data=b"stop_tagall"))
async def stop_tagall_handler(event):
    global GLOBAL_STOP

    GLOBAL_STOP = True
    running_tagall[event.chat_id] = False

    # 🔥 CANCEL SEMUA TASK LANGSUNG
    tasks = tagall_tasks.get(event.chat_id, [])
    for t in tasks:
        t.cancel()

    await event.answer("🛑 Tagall dihentikan TOTAL!", alert=True)

    try:
        await event.edit("🛑 TAGALL DIHENTIKAN", buttons=[])
    except:
        pass

    # reset biar bisa dipake lagi
    await asyncio.sleep(1)
    GLOBAL_STOP = False


