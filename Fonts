FONT_CACHE = {}

def gen_font(text, new_font):
    new_font = " ".join(new_font).split()
    for q in text:
        if q in _default:
            text = text.replace(q, new_font[_default.index(q)])
    return text


# ================= MENU =================
def build_menu():
    buttons = [
        [Button.inline("🎲 Random", b"font:random"),
         Button.inline("📋 List", b"font:list")]
    ]

    font_names = list(Fonts.keys())
    for i in range(0, len(font_names), 4):
        row = [
            Button.inline(name, f"font:{name}".encode())
            for name in font_names[i:i+4]
        ]
        buttons.append(row)

    return buttons


def register_font(client):

    @client.on(events.NewMessage(pattern=r"^[\/\.]font(?: |$)(.*)"))
    async def font_handler(event):
        text = event.pattern_match.group(1).strip()
        reply = await event.get_reply_message()

        if reply:
            text = reply.text

        if not text:
            return await event.reply("📌 kirim text atau reply pesan dulu.")

        FONT_CACHE[event.chat_id] = text

        await event.reply("✨ pilih font:", buttons=build_menu())


    @client.on(events.CallbackQuery(pattern=b"font:"))
    async def font_callback(event):
        data = event.data.decode().split(":", 1)[1]

        text = FONT_CACHE.get(event.chat_id)
        if not text:
            return await event.answer("❌ tidak ada text", alert=True)

        if data == "list":
            msg = "📚 FONT LIST:\n\n" + "\n".join(f"• `{f}`" for f in Fonts)
            return await event.edit(msg, buttons=build_menu())

        if data == "random":
            name = random.choice(list(Fonts.keys()))
        else:
            name = data

        if name not in Fonts:
            return await event.answer("❌ font tidak ditemukan", alert=True)

        result = gen_font(text, Fonts[name])

        await event.edit(
            f"✨ FONT RESULT\n\n🎯 `{name}`\n\n`{result}`",
            buttons=[
                [Button.inline("🔁 random", b"font:random"),
                 Button.inline("🔙 back", b"font:back")]
            ]
        )


    @client.on(events.CallbackQuery(pattern=b"font:back"))
    async def font_back(event):
        await event.edit("✨ pilih font:", buttons=build_menu())
